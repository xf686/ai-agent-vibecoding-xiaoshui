          "tool_use_id": "call_function_ug6fzyroiecp_1",
          "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>像素跑酷</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            background: #1a1a2e;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            font-family: 'Press Start 2P', monospace;\n        }\n        \n        #gameContainer {\n            position: relative;\n            border: 4px solid #e94560;\n            box-shadow: 0 0 30px rgba(233, 69, 96, 0.5);\n        }\n        \n        #gameCanvas {\n            display: block;\n            background: #16213e;\n        }\n        \n        #ui {\n            position: absolute;\n            top: 10px;\n            left: 10px;\n            color: #fff;\n            font-size: 16px;\n            text-shadow: 2px 2px #000;\n        }\n        \n        #gameOver {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            text-align: center;\n            display: none;\n        }\n        \n        #gameOver h1 {\n            color: #e94560;\n            font-size: 32px;\n            margin-bottom: 20px;\n            text-shadow: 3px 3px #000;\n        }\n        \n        #gameOver p {\n            color: #fff;\n            font-size: 14px;\n            margin-bottom: 20px;\n        }\n        \n        #restartBtn {\n            background: #e94560;\n            color: #fff;\n            border: none;\n            padding: 15px 30px;\n            font-family: inherit;\n            font-size: 14px;\n            cursor: pointer;\n            transition: all 0.2s;\n        }\n        \n        #restartBtn:hover {\n            background: #ff6b6b;\n            transform: scale(1.1);\n        }\n        \n        #startScreen {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            text-align: center;\n        }\n        \n        #startScreen h1 {\n            color: #e94560;\n            font-size: 28px;\n            margin-bottom: 30px;\n            text-shadow: 3px 3px #000;\n        }\n        \n        #startScreen p {\n            color: #aaa;\n            font-size: 12px;\n            margin-bottom: 10px;\n        }\n        \n        #startBtn {\n            background: #0f3460;\n            color: #fff;\n            border: 3px solid #e94560;\n            padding: 15px 40px;\n            font-family: inherit;\n            font-size: 14px;\n            cursor: pointer;\n            margin-top: 20px;\n            transition: all 0.2s;\n        }\n        \n        #startBtn:hover {\n            background: #e94560;\n        }\n        \n        .controls {\n            position: absolute;\n            bottom: 10px;\n            right: 10px;\n            color: #666;\n            font-size: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"gameContainer\">\n        <canvas id=\"gameCanvas\" width=\"800\" height=\"400\"></canvas>\n        <div id=\"ui\">分数: <span id=\"score\">0</span></div>\n        \n        <div id=\"startScreen\">\n            <h1>像素跑酷</h1>\n            <p>按 空格键 或 点击 跳跃</p>\n            <button id=\"startBtn\">开始游戏</button>\n        </div>\n        \n        <div id=\"gameOver\">\n            <h1>GAME OVER</h1>\n            <p>最终分数: <span id=\"finalScore\">0</span></p>\n            <button id=\"restartBtn\">再来一次</button>\n        </div>\n        \n        <div class=\"controls\">SPACE / CLICK = 跳跃</div>\n    </div>\n\n    <script>\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        \n        const scoreEl = document.getElementById('score');\n        const finalScoreEl = document.getElementById('finalScore');\n        const gameOverScreen = document.getElementById('gameOver');\n        const startScreen = document.getElementById('startScreen');\n        const startBtn = document.getElementById('startBtn');\n        const restartBtn = document.getElementById('restartBtn');\n        \n        let gameRunning = false;\n        let score = 0;\n        let gameSpeed = 5;\n        let frameCount = 0;\n        \n        // 玩家\n        const player = {\n            x: 100,\n            y: 320,\n            width: 30,\n            height: 30,\n            velocity: 0,\n            grounded: true,\n            jumpPower: -15,\n            gravity: 0.8\n        };\n        \n        // 障碍物数组\n        let obstacles = [];\n        \n        // 地面\n        const ground = {\n            y: 350,\n            height: 50\n        };\n        \n        // 背景星星\n        let stars = [];\n        \n        function initStars() {\n            stars = [];\n            for (let i = 0; i < 50; i++) {\n                stars.push({\n                    x: Math.random() * canvas.width,\n                    y: Math.random() * (ground.y - 50),\n                    size: Math.random() * 2 + 1,\n                    speed: Math.random() * 0.5 + 0.2\n                });\n            }\n        }\n        \n        function drawBackground() {\n            // 夜空渐变\n            const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);\n            gradient.addColorStop(0, '#0f0c29');\n            gradient.addColorStop(0.5, '#302b63');\n            gradient.addColorStop(1, '#24243e');\n            ctx.fillStyle = gradient;\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            // 星星\n            ctx.fillStyle = '#fff';\n            stars.forEach(star => {\n                ctx.fillRect(star.x, star.y, star.size, star.size);\n                star.x -= star.speed;\n                if (star.x < 0) {\n                    star.x = canvas.width;\n                    star.y = Math.random() * (ground.y - 50);\n                }\n            });\n        }\n        \n        function drawGround() {\n            // 地面\n            ctx.fillStyle = '#2d2d44';\n            ctx.fillRect(0, ground.y, canvas.width, ground.height);\n            \n            // 地面线条（像素风格）\n            ctx.fillStyle = '#3d3d5c';\n            for (let x = 0; x < canvas.width; x += 40) {\n                ctx.fillRect(x, ground.y, 2, 10);\n            }\n            \n            // 地面顶部装饰\n            ctx.fillStyle = '#e94560';\n            ctx.fillRect(0, ground.y, canvas.width, 4);\n        }\n        \n        function drawPlayer() {\n            // 玩家本体\n            ctx.fillStyle = '#00d9ff';\n            ctx.fillRect(player.x, player.y, player.width, player.height);\n            \n            // 像素描边\n            ctx.fillStyle = '#00a8cc';\n            ctx.fillRect(player.x, player.y, player.width, 4);\n            ctx.fillRect(player.x, player.y, 4, player.height);\n            \n            ctx.fillStyle = '#005f73';\n            ctx.fillRect(player.x, player.y + player.height - 4, player.width, 4);\n            ctx.fillRect(player.x + player.width - 4, player.y, 4, player.height);\n            \n            // 眼睛\n            ctx.fillStyle = '#fff';\n            ctx.fillRect(player.x + 18, player.y + 8, 6, 6);\n            ctx.fillStyle = '#000';\n            ctx.fillRect(player.x + 20, player.y + 10, 2, 2);\n        }\n        \n        function drawObstacles() {\n            obstacles.forEach(obs => {\n                if (obs.type === 'spike') {\n                    // 尖刺障碍物\n                    ctx.fillStyle = '#ff6b6b';\n                    ctx.beginPath();\n                    ctx.moveTo(obs.x, obs.y + obs.height);\n                    ctx.lineTo(obs.x + obs.width / 2, obs.y);\n                    ctx.lineTo(obs.x + obs.width, obs.y + obs.height);\n                    ctx.closePath();\n                    ctx.fill();\n                    \n                    ctx.fillStyle = '#ff4757';\n                    ctx.beginPath();\n                    ctx.moveTo(obs.x + obs.width / 2, obs.y);\n                    ctx.lineTo(obs.x + obs.width, obs.y + obs.height);\n                    ctx.lineTo(obs.x + obs.width / 2, obs.y + obs.height / 2);\n                    ctx.closePath();\n                    ctx.fill();\n                } else {\n                    // 方块障碍物\n                    ctx.fillStyle = '#ff6b6b';\n                    ctx.fillRect(obs.x, obs.y, obs.width, obs.height);\n                    \n                    ctx.fillStyle = '#ff4757';\n                    ctx.fillRect(obs.x, obs.y, obs.width, 4);\n                    ctx.fillRect(obs.x, obs.y, 4, obs.height);\n                    \n                    ctx.fillStyle = '#c92a2a';\n                    ctx.fillRect(obs.x, obs.y + obs.height - 4, obs.width, 4);\n                    ctx.fillRect(obs.x + obs.width - 4, obs.y, 4, obs.height);\n                }\n            });\n        }\n        \n        function updatePlayer() {\n            // 重力\n            player.velocity += player.gravity;\n            player.y += player.velocity;\n            \n            // 地面碰撞\n            if (player.y + player.height > ground.y) {\n                player.y = ground.y - player.height;\n                player.velocity = 0;\n                player.grounded = true;\n            }\n        }\n        \n        function updateObstacles() {\n            // 移动障碍物\n            obstacles.forEach(obs => {\n                obs.x -= gameSpeed;\n            });\n            \n            // 移除屏幕外的障碍物\n            obstacles = obstacles.filter(obs => obs.x + obs.width > 0);\n            \n            // 生成新障碍物\n            if (frameCount % 90 === 0 && Math.random() > 0.3) {\n                const type = Math.random() > 0.5 ? 'spike' : 'block';\n                const height = type === 'spike' ? 30 : 30 + Math.random() * 20;\n                obstacles.push({\n                    x: canvas.width,\n                    y: ground.y - height,\n                    width: 30,\n                    height: height,\n                    type: type\n                });\n            }\n        }\n        \n        function checkCollision() {\n            for (let obs of obstacles) {\n                if (player.x < obs.x + obs.width &&\n                    player.x + player.width > obs.x &&\n                    player.y < obs.y + obs.height &&\n                    player.y + player.height > obs.y) {\n                    return true;\n                }\n            }\n            return false;\n        }\n        \n        function jump() {\n            if (player.grounded) {\n                player.velocity = player.jumpPower;\n                player.grounded = false;\n            }\n        }\n        \n        function gameLoop() {\n            if (!gameRunning) return;\n            \n            // 清空画布\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            // 绘制背景\n            drawBackground();\n            drawGround();\n            \n            // 更新\n            updatePlayer();\n            updateObstacles();\n            \n            // 绘制\n            drawObstacles();\n            drawPlayer();\n            \n            // 碰撞检测\n            if (checkCollision()) {\n                gameOver();\n                return;\n            }\n            \n            // 分数\n            frameCount++;\n            if (frameCount % 10 === 0) {\n                score++;\n                scoreEl.textContent = score;\n                \n                // 难度增加\n                if (score % 100 === 0) {\n                    gameSpeed += 0.5;\n                }\n            }\n            \n            requestAnimationFrame(gameLoop);\n        }\n        \n        function startGame() {\n            gameRunning = true;\n            score = 0;\n            gameSpeed = 5;\n            frameCount = 0;\n            obstacles = [];\n            player.y = 320;\n            player.velocity = 0;\n            player.grounded = true;\n            \n            scoreEl.textContent = '0';\n            startScreen.style.display = 'none';\n            gameOverScreen.style.display = 'none';\n            \n            initStars();\n            gameLoop();\n        }\n        \n        function gameOver() {\n            gameRunning = false;\n            finalScoreEl.textContent = score;\n            gameOverScreen.style.display = 'block';\n        }\n        \n        // 事件监听\n        document.addEventListener('keydown', (e) => {\n            if (e.code === 'Space') {\n                e.preventDefault();\n                if (gameRunning) {\n                    jump();\n                } else if (gameOverScreen.style.display === 'block') {\n                    startGame();\n                } else if (startScreen.style.display !== 'none') {\n                    startGame();\n                }\n            }\n        });\n        \n        canvas.addEventListener('click', () => {\n            if (gameRunning) {\n                jump();\n            }\n        });\n        \n        startBtn.addEventListener('click', startGame);\n        restartBtn.addEventListener('click', startGame);\n        \n        // 初始绘制\n        initStars();\n        drawBackground();\n        drawGround();\n        drawPlayer();\n    </script>\n</body>\n</html>"
        }
      ]
